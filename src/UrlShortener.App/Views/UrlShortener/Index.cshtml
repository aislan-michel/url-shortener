@model UrlShortener.App.Models.ShortUrlListViewModel

@{
    ViewData["Title"] = "URL Shortener";
    var shortCode = Model.ShortCodeFilter;
    var totalUrls = Model.TotalItems;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
    <div>
        <h2 class="mb-1">Minhas URLs encurtadas</h2>
        <p class="text-muted mb-0">Gerencie seus links curtos, veja o histórico e compartilhe com facilidade.</p>
    </div>
    <a class="btn btn-warning btn-icon text-dark shadow-sm" asp-action="Create" title="Criar novo" aria-label="Criar novo">
        <i class="bi bi-plus-lg"></i>
    </a>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="get" asp-action="Index">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label for="shortCodeFilter" class="form-label">Código</label>
                            <input id="shortCodeFilter" name="shortCode" type="text" class="form-control" value="@shortCode" placeholder="Digite o Código" />
                        </div>
                        <div class="col-md-6 d-flex flex-wrap gap-2 align-items-center justify-content-md-end">
                            <button type="submit" class="btn btn-primary btn-icon" title="Buscar" aria-label="Buscar">
                                <i class="bi bi-search"></i>
                            </button>
                            <a class="btn btn-outline-secondary btn-icon" asp-action="Index" asp-controller="UrlShortener" title="Limpar" aria-label="Limpar">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
                    <div>
                        <h3 class="h6 mb-1">Resultados</h3>
                        <p class="text-muted mb-0">@totalUrls resultado(s) encontrado(s) · mostrando @Model.StartItem–@Model.EndItem</p>
                    </div>
                </div>

                <!-- Desktop view -->
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Código</th>
                                <th scope="col">Criado em</th>
                                <th scope="col">Status</th>
                                <th scope="col">URL original</th>
                                <th scope="col">URL curta</th>
                                <th scope="col">Clique(s)</th>
                                <th scope="col">Expira</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ShortUrls.Any())
                            {
                                foreach (var shortUrl in Model.ShortUrls)
                                {
                                    <tr>
                                        <th scope="row">@shortUrl.ShortCode</th>
                                        <td>@shortUrl.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            @if (shortUrl.Active)
                                            {
                                                <a href="@Url.Action("Deactivate", "UrlShortener", new { shortCode = shortUrl.ShortCode })" class="badge bg-success text-decoration-none" aria-label="Desativar link curto">Ativo</a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Activate", "UrlShortener", new { shortCode = shortUrl.ShortCode })" class="badge bg-danger text-decoration-none" aria-label="Ativar link curto">Inativo</a>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column gap-1">
                                                <div class="url-copy-row">
                                                    <span class="url-copy-link" title="@shortUrl.OriginalUrl">@shortUrl.OriginalUrl</span>
                                                    <button type="button" class="btn btn-link btn-sm text-decoration-none copy js-copy-btn url-copy-action" data-copy-text="@shortUrl.OriginalUrl" data-bs-toggle="tooltip" data-bs-placement="top" title="Copiar URL original" aria-label="Copiar URL original">
                                                        <i class="bi bi-clipboard"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="url-copy-row">
                                                <a class="link url-copy-link js-short-url-link" href="@shortUrl.ShortCode" target="_blank" rel="noopener noreferrer" title="@shortUrl.ShortUrlFull">@shortUrl.ShortUrlFull</a>
                                                <button type="button" class="btn btn-link btn-sm text-decoration-none copy js-copy-btn url-copy-action" data-copy-text="@shortUrl.ShortUrlFull" data-bs-toggle="tooltip" data-bs-placement="top" title="Copiar URL curta" aria-label="Copiar URL curta">
                                                    <i class="bi bi-clipboard"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@shortUrl.ClickCounter</span>
                                        </td>
                                        <td>@(shortUrl.Expires.HasValue ? shortUrl.Expires.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-dark btn-icon js-qr-btn" data-short-code="@shortUrl.ShortCode" title="Gerar QR Code" aria-label="Gerar QR Code">
                                                    <i class="bi bi-qr-code"></i>
                                                </button>
                                                <a class="btn btn-outline-dark btn-icon" asp-action="Details" asp-route-id="@shortUrl.ShortCode" title="Ver detalhes" aria-label="Ver detalhes">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a class="btn btn-outline-dark btn-icon" asp-action="Update" asp-route-id="@shortUrl.ShortCode" title="Editar" aria-label="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-danger btn-icon js-open-delete-modal" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" data-delete-url="@Url.Action("Delete", "UrlShortener", new { id = shortUrl.ShortCode })" data-original-url="@shortUrl.OriginalUrl" title="Excluir" aria-label="Excluir">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="8" class="text-center text-muted py-4">Nenhum resultado encontrado. <a class="link-primary" asp-action="Create">Crie um link curto</a>.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Navegação de páginas" class="mt-4">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { shortCode, page = Model.PageIndex - 1 })" aria-label="Página anterior">Anterior</a>
                            </li>
                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { shortCode, page = i })">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { shortCode, page = Model.PageIndex + 1 })" aria-label="Próxima página">Próxima</a>
                            </li>
                        </ul>
                    </nav>
                }

                <!-- Mobile view -->
                <div class="d-md-none">
                    @if (Model.ShortUrls.Any())
                    {
                        <div class="row g-3">
                            @foreach (var shortUrl in Model.ShortUrls)
                            {
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                                <div>
                                                    <h5 class="h6 mb-1">@shortUrl.ShortCode</h5>
                                                    <span class="text-muted small">Criado em @shortUrl.CreatedAt.ToString("dd/MM/yyyy")</span>
                                                </div>
                                                <span class="badge @(shortUrl.Active ? "bg-success" : "bg-danger")">@(shortUrl.Active ? "Ativo" : "Inativo")</span>
                                            </div>

                                            <div class="mb-2">
                                                <div class="small text-uppercase text-muted mb-1">URL original</div>
                                                <div class="url-copy-row">
                                                    <a class="url-copy-link" href="@shortUrl.OriginalUrl" target="_blank" rel="noopener noreferrer" title="@shortUrl.OriginalUrl">@shortUrl.OriginalUrl</a>
                                                    <button type="button" class="btn btn-link btn-sm text-decoration-none copy js-copy-btn url-copy-action" data-copy-text="@shortUrl.OriginalUrl" data-bs-toggle="tooltip" data-bs-placement="top" title="Copiar URL original" aria-label="Copiar URL original">
                                                        <i class="bi bi-clipboard"></i>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="mb-2">
                                                <div class="small text-uppercase text-muted mb-1">URL curta</div>
                                                <div class="url-copy-row">
                                                    <a class="url-copy-link js-short-url-link" href="@shortUrl.ShortUrlFull" target="_blank" rel="noopener noreferrer" title="@shortUrl.ShortUrlFull">@shortUrl.ShortUrlFull</a>
                                                    <button type="button" class="btn btn-link btn-sm text-decoration-none copy js-copy-btn url-copy-action" data-copy-text="@shortUrl.ShortUrlFull" data-bs-toggle="tooltip" data-bs-placement="top" title="Copiar URL curta" aria-label="Copiar URL curta">
                                                        <i class="bi bi-clipboard"></i>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="mb-2">
                                                <div class="small text-uppercase text-muted mb-1">Cliques</div>
                                                <span class="badge bg-secondary">@shortUrl.ClickCounter</span>
                                            </div>

                                            <div class="mb-3 small text-muted">Expira: @(shortUrl.Expires.HasValue ? shortUrl.Expires.Value.ToString("dd/MM/yyyy") : "N/A")</div>

                                            <div class="btn-group btn-group-sm w-100" role="group">
                                                <button type="button" class="btn btn-outline-dark btn-icon js-qr-btn" data-short-code="@shortUrl.ShortCode" title="Gerar QR Code" aria-label="Gerar QR Code">
                                                    <i class="bi bi-qr-code"></i>
                                                </button>
                                                <a class="btn btn-outline-dark btn-icon" asp-action="Details" asp-route-id="@shortUrl.ShortCode" title="Ver detalhes" aria-label="Ver detalhes">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a class="btn btn-outline-dark btn-icon" asp-action="Update" asp-route-id="@shortUrl.ShortCode" title="Editar" aria-label="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-danger btn-icon js-open-delete-modal" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" data-delete-url="@Url.Action("Delete", "UrlShortener", new { id = shortUrl.ShortCode })" data-original-url="@shortUrl.OriginalUrl" title="Excluir" aria-label="Excluir">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">Nenhum resultado encontrado. <a class="link-primary" asp-action="Create">Crie um link curto</a>.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="qrCodeModalLabel">QR Code</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div id="qrCodeModalBody" class="modal-body text-center"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteConfirmationModal" tabindex="-1" aria-labelledby="deleteConfirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="deleteConfirmationModalLabel">Confirmar exclusão</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div id="deleteConfirmationBody" class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <a id="deleteConfirmationButton" class="btn btn-danger" href="#">Excluir</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generateQrCode(shortCode) {
            $.get(`/UrlShortener/QrCode/${shortCode}`, function (data) {
                $("#qrCodeModalBody").empty().html(`<img src='data:image/png;base64,${data.qrCodeBytes}' class='img-fluid mx-auto d-block' alt='QR Code para ${shortCode}'/>`);
                $("#qrCodeModal").modal('show');
            });
        }

        function copyText(text) {
            if (!navigator.clipboard) {
                return;
            }

            navigator.clipboard.writeText(text);
        }

        $(function () {
            $('[data-bs-toggle="tooltip"]').tooltip();

            var shouldReloadAfterShortUrl = false;

            $(document).on('click', '.js-short-url-link', function () {
                shouldReloadAfterShortUrl = true;
            });

            function reloadIfNeeded() {
                if (shouldReloadAfterShortUrl) {
                    shouldReloadAfterShortUrl = false;
                    window.location.reload();
                }
            }

            $(window).on('focus', reloadIfNeeded);
            document.addEventListener('visibilitychange', function () {
                if (document.visibilityState === 'visible') {
                    reloadIfNeeded();
                }
            });

            $(document).on('click', '.js-copy-btn', function () {
                copyText($(this).data('copy-text'));
                alert('Texto copiado para a área de transferência!');
            });

            $(document).on('click', '.js-qr-btn', function () {
                generateQrCode($(this).data('short-code'));
            });

            $(document).on('click', '.js-open-delete-modal', function () {
                var originalUrl = $(this).data('original-url');
                var deleteUrl = $(this).data('delete-url');

                $('#deleteConfirmationBody').text(`Deseja realmente excluir: ${originalUrl}?`);
                $('#deleteConfirmationButton').attr('href', deleteUrl);
            });
        });
    </script>
}


