@model UrlShortener.App.Models.CreateShortUrl

@{
    ViewData["Title"] = "Create";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="mb-4">
                    <h2 class="h5 mb-1">Criar novo link</h2>
                    <p class="text-muted mb-0">Defina um código curto, informe a URL de destino e, se quiser, agende a expiração.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <p class="mb-2">Por favor corrija os erros abaixo:</p>
                        <ul class="mb-0">
                            @foreach (var modelStateEntry in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelStateEntry.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form method="post" asp-action="Create" novalidate>
                    <div class="mb-3">
                        <label class="form-label">Short code</label>
                        <input class="form-control" type="text" name="shortCode" placeholder="my-links" value="@Model.ShortCode" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Long URL</label>
                        <input class="form-control" type="url" name="url" placeholder="https://example.com" value="@Model.Url" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Expires in</label>
                        <input class="form-control" type="date" name="expires" value='@(Model.Expires.HasValue ? Model.Expires.Value.ToString("yyyy-MM-dd") : "")' />
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2" aria-hidden="true"></i>Salvar
                        </button>
                        <a class="btn btn-outline-secondary" href='@Url.Action("Index", "UrlShortener")'>
                            <i class="bi bi-arrow-left-short me-2" aria-hidden="true"></i>Voltar para lista
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
