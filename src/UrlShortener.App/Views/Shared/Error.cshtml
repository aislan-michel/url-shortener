@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<main class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
        <div class="card shadow-sm p-4 border-danger">
            <div class="mb-4">
                <h1 class="h4 text-danger mb-2">Ocorreu um erro</h1>
                <p class="text-muted mb-0">Desculpe, não foi possível processar a sua solicitação.</p>
            </div>

            <div class="mb-3">
                <h2 class="h6">Detalhes</h2>
                <p class="mb-2">Por favor revise o ambiente e as configurações do servidor.</p>
            </div>

            @if (Model.ShowRequestId)
            {
                <div class="mb-3">
                    <strong>Request ID:</strong>
                    <code>@Model.RequestId</code>
                </div>
            }

            <div class="alert alert-warning" role="alert">
                <strong>Nota:</strong> mantenha o modo de desenvolvimento desativado em produção.
            </div>
        </div>
    </div>
</main>
